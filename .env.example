# ─── Flask Configuration ─────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development                      # development | production
SECRET_KEY=your-secret-key-here            # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ─── JWT Configuration ──────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here    # Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ACCESS_TOKEN_EXPIRES=315360000         # Token lifetime in seconds (default: ~10 years)

# ─── Database Configuration ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=py_voip
DB_USERNAME=root
DB_PASSWORD=root
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock   # Remove this line if not using MAMP

# ─── Server Configuration ───────────────────────────────────────────
SERVER_HOST=0.0.0.0                        # 0.0.0.0 = listen on all interfaces
SERVER_PORT=5001

# ─── TURN Server Configuration (for WebRTC NAT traversal) ───────────
TURN_SERVER_HOST=your-turn-server-ip       # Local network IP where coturn runs
TURN_SERVER_PORT=3478
TURN_USERNAME=voicelink
TURN_PASSWORD=your-turn-password

# ─── Web Push (VAPID) Configuration ─────────────────────────────────
# Generate keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v)"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key-pem
VAPID_CLAIMS_EMAIL=mailto:admin@voicelink.local
